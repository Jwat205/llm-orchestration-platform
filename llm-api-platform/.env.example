# Database
POSTGRES_DB=llm_platform
POSTGRES_USER=llm_user
POSTGRES_PASSWORD=securepassword123

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# JWT Secret Key
JWT_SECRET_KEY=your_jwt_secret_key_here

# Django Settings
DJANGO_SETTINGS_MODULE=config.settings.production

# Django Auth URL (used by FastAPI to validate tokens)
DJANGO_AUTH_URL=http://django:8000/api/auth/verify/

# Other environment variables
API_KEY_EXPIRE_DAYS=30
MODEL_PATH=/models/microsoft-DialoGPT-medium
