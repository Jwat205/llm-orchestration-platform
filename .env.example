# LLM API Platform - Environment Variables Template
# Copy this file to .env and update with your actual values

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Django Settings
DEBUG=True
DJANGO_SECRET_KEY=your-django-secret-key-here
DJANGO_SETTINGS_MODULE=core.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,django

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL Database
DATABASE_URL=postgresql://postgres:dev_password@localhost:5432/llm_api
DB_HOST=postgres
DB_NAME=llm_api
DB_USER=postgres
DB_PASSWORD=dev_password
DB_PORT=5432

# Redis Cache
REDIS_URL=redis://:dev_password@localhost:6379/0
REDIS_HOST=redis
REDIS_PASSWORD=dev_password
REDIS_PORT=6379

# ============================================================================
# API KEYS (Update these with your actual keys)
# ============================================================================

# OpenAI API
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_ORG_ID=your-openai-org-id-here

# Anthropic Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Hugging Face
HUGGINGFACE_API_KEY=your-huggingface-token-here

# Replicate (for additional models)
REPLICATE_API_TOKEN=your-replicate-token-here

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# API Security
API_KEY_PREFIX=llm_
ENCRYPTION_KEY=your-encryption-key-here

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

# Development Email (using MailHog)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@llm-platform.local

# Production Email (uncomment and configure for production)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# ============================================================================
# FILE STORAGE
# ============================================================================

# Local File Storage
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/static
MEDIA_URL=/media/
STATIC_URL=/static/

# AWS S3 (for production)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=your-cdn-domain.com

# ============================================================================
# MODEL CONFIGURATION
# ============================================================================

# Model Storage
MODEL_CACHE_DIR=/app/models
HF_HOME=/app/huggingface_cache
TRANSFORMERS_CACHE=/app/transformers_cache

# Model Settings
DEFAULT_MODEL=llama-2-7b-chat
MAX_TOKENS_DEFAULT=150
TEMPERATURE_DEFAULT=0.7

# Inference Settings
GPU_ENABLED=True
BATCH_SIZE_DEFAULT=1
MAX_CONCURRENT_REQUESTS=10

# ============================================================================
# SERVICE URLS
# ============================================================================

# Internal Service URLs
DJANGO_URL=http://localhost:8000
FASTAPI_URL=http://localhost:8001
FRONTEND_URL=http://localhost:3000

# External APIs
WEBHOOK_BASE_URL=http://localhost:8001

# ============================================================================
# MONITORING & LOGGING
# ============================================================================

# Sentry (Error Monitoring)
SENTRY_DSN=your-sentry-dsn-here
SENTRY_ENVIRONMENT=development

# Logging Configuration
LOG_LEVEL=DEBUG
LOG_FORMAT=json
LOG_FILE=/app/logs/app.log

# Monitoring
MONITORING_ENABLED=True
METRICS_ENABLED=True
HEALTH_CHECK_ENABLED=True

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Development Features
ENABLE_DEBUG_TOOLBAR=True
ENABLE_SILK_PROFILING=True
ENABLE_SWAGGER_UI=True

# API Features
ENABLE_API_THROTTLING=False
ENABLE_CACHING=True
ENABLE_RATE_LIMITING=True

# AI Features
ENABLE_FUNCTION_CALLING=True
ENABLE_STREAMING=True
ENABLE_EMBEDDINGS=True
ENABLE_FINE_TUNING=True

# ============================================================================
# EXTERNAL INTEGRATIONS
# ============================================================================

# Stripe (for billing)
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Analytics
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
MIXPANEL_TOKEN=your-mixpanel-token

# Support
INTERCOM_APP_ID=your-intercom-app-id
ZENDESK_SUBDOMAIN=your-subdomain

# ============================================================================
# PERFORMANCE SETTINGS
# ============================================================================

# Database Connection Pool
DB_CONN_MAX_AGE=300
DB_CONN_POOL_SIZE=20

# Cache Settings
CACHE_TTL_DEFAULT=300
CACHE_TTL_MODELS=3600
CACHE_TTL_USER_DATA=900

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ============================================================================
# DEVELOPMENT OVERRIDES
# ============================================================================

# Debug Settings (development only)
DJANGO_DEBUG_TOOLBAR=True
SQL_DEBUG=True
TEMPLATE_DEBUG=True

# Testing
TEST_DATABASE_NAME=test_llm_api
PYTEST_TIMEOUT=300

# Development Tools
SHELL_PLUS_PRINT_SQL=True
RUNSERVER_PLUS_EXTRA_ARGS=--threaded

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# HTTPS (set to True in production)
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_BROWSER_XSS_FILTER=True

# Session Security
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# CSRF Protection
CSRF_COOKIE_SECURE=False
CSRF_COOKIE_HTTPONLY=True
CSRF_TRUSTED_ORIGINS=http://localhost:3000