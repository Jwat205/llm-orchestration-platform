{
  "dashboard": {
    "id": null,
    "title": "LLM Platform - SLA & Performance Dashboard",
    "tags": ["llm", "sla", "performance"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "99.5% Uptime SLA",
        "type": "stat",
        "targets": [
          {
            "expr": "sla:availability:24h * 100",
            "legendFormat": "24h Availability"
          },
          {
            "expr": "sla:availability:30d * 100",
            "legendFormat": "30d Availability"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 99},
                {"color": "green", "value": 99.5}
              ]
            },
            "unit": "percent",
            "min": 99,
            "max": 100
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "1,000+ RPS Capacity",
        "type": "stat",
        "targets": [
          {
            "expr": "sla:throughput:5m",
            "legendFormat": "Current RPS"
          },
          {
            "expr": "max_over_time(sla:throughput:5m[1h])",
            "legendFormat": "Peak RPS (1h)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 500},
                {"color": "green", "value": 1000}
              ]
            },
            "unit": "reqps",
            "min": 0
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "<100ms Latency Target",
        "type": "stat",
        "targets": [
          {
            "expr": "sla:latency_p95:5m * 1000",
            "legendFormat": "95th Percentile"
          },
          {
            "expr": "sla:latency_p99:5m * 1000",
            "legendFormat": "99th Percentile"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 50},
                {"color": "red", "value": 100}
              ]
            },
            "unit": "ms",
            "max": 200
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0}
      },
      {
        "id": 4,
        "title": "70%+ Cache Hit Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "sla:cache_hit_rate:5m * 100",
            "legendFormat": "Current Hit Rate"
          },
          {
            "expr": "sla:cache_hit_rate:24h * 100",
            "legendFormat": "24h Hit Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 50},
                {"color": "green", "value": 70}
              ]
            },
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0}
      },
      {
        "id": 5,
        "title": "1M+ Monthly Requests",
        "type": "stat",
        "targets": [
          {
            "expr": "increase(http_requests_total[30d])",
            "legendFormat": "30-day Total"
          },
          {
            "expr": "increase(http_requests_total[24h]) * 30",
            "legendFormat": "Projected Monthly (24h avg)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 500000},
                {"color": "green", "value": 1000000}
              ]
            },
            "unit": "short",
            "min": 0
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 6,
        "title": "<50ms Cached Responses",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{cached=\"true\"}[5m])) * 1000",
            "legendFormat": "50th Percentile"
          },
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{cached=\"true\"}[5m])) * 1000",
            "legendFormat": "95th Percentile"
          },
          {
            "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{cached=\"true\"}[5m])) * 1000",
            "legendFormat": "99th Percentile"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 25},
                {"color": "red", "value": 50}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 7,
        "title": "Request Volume Trends",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(http_requests_total[5m]) * 60",
            "legendFormat": "Requests/min"
          },
          {
            "expr": "increase(http_requests_total[1h])",
            "legendFormat": "Hourly Total"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16}
      },
      {
        "id": 8,
        "title": "SLA Compliance Summary",
        "type": "table",
        "targets": [
          {
            "expr": "sla:availability:24h * 100",
            "legendFormat": "Availability %",
            "format": "table"
          },
          {
            "expr": "sla:throughput:1h",
            "legendFormat": "Avg RPS (1h)",
            "format": "table"
          },
          {
            "expr": "sla:latency_p95:5m * 1000",
            "legendFormat": "Latency P95 (ms)",
            "format": "table"
          },
          {
            "expr": "sla:cache_hit_rate:24h * 100",
            "legendFormat": "Cache Hit Rate %",
            "format": "table"
          },
          {
            "expr": "increase(http_requests_total[24h])",
            "legendFormat": "Daily Requests",
            "format": "table"
          }
        ],
        "fieldConfig": {
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Availability %"},
              "properties": [
                {
                  "id": "thresholds",
                  "value": {
                    "steps": [
                      {"color": "red", "value": 0},
                      {"color": "yellow", "value": 99},
                      {"color": "green", "value": 99.5}
                    ]
                  }
                }
              ]
            },
            {
              "matcher": {"id": "byName", "options": "Avg RPS (1h)"},
              "properties": [
                {
                  "id": "thresholds",
                  "value": {
                    "steps": [
                      {"color": "red", "value": 0},
                      {"color": "yellow", "value": 500},
                      {"color": "green", "value": 1000}
                    ]
                  }
                }
              ]
            }
          ]
        },
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24}
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "5s"
  }
}